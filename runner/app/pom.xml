<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.quarkiverse.flow</groupId>
        <artifactId>quarkus-flow-runner-parent</artifactId>
        <version>1.0.0-SNAPSHOT</version>
    </parent>

    <artifactId>quarkus-flow-runner-app</artifactId>
    <name>Quarkus Flow :: Runner :: App</name>
    <description>Pre-built Runner application for Docker images - not released as Maven artifact</description>

    <properties>
        <skipITs>true</skipITs>
        <maven.deploy.skip>true</maven.deploy.skip>
        <build.timestamp>${maven.build.timestamp}</build.timestamp>
        <maven.build.timestamp.format>yyyy-MM-dd'T'HH:mm:ss'Z'</maven.build.timestamp.format>
        <!-- Variant is set by the active profile, defaults to minimal -->
        <image.variant>minimal</image.variant>
    </properties>

    <dependencies>
        <!-- Core Runner -->
        <dependency>
            <groupId>io.quarkiverse.flow</groupId>
            <artifactId>quarkus-flow-runner</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!-- REST + JSON support (already included in runner, explicit for clarity) -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-rest-jackson</artifactId>
        </dependency>

        <!-- OpenAPI/Swagger UI -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-smallrye-openapi</artifactId>
        </dependency>

        <!-- Health -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-smallrye-health</artifactId>
        </dependency>

        <!-- Metrics -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-micrometer-registry-prometheus</artifactId>
        </dependency>

        <!-- Test dependencies -->
        <dependency>
            <groupId>io.quarkus</groupId>
            <artifactId>quarkus-junit</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>io.rest-assured</groupId>
            <artifactId>rest-assured</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.awaitility</groupId>
            <artifactId>awaitility</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Messaging dependencies for testing event emission -->
        <dependency>
            <groupId>io.quarkiverse.flow</groupId>
            <artifactId>quarkus-flow-messaging</artifactId>
            <version>${project.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>io.smallrye.reactive</groupId>
            <artifactId>smallrye-reactive-messaging-in-memory</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <filtering>true</filtering>
                <includes>
                    <include>**/*.html</include>
                </includes>
            </resource>
            <resource>
                <directory>src/main/resources</directory>
                <filtering>false</filtering>
                <excludes>
                    <exclude>**/*.html</exclude>
                </excludes>
            </resource>
            <!-- Kubernetes manifests with version filtering -->
            <resource>
                <directory>src/main/k8s</directory>
                <filtering>true</filtering>
                <targetPath>${project.build.directory}/k8s</targetPath>
            </resource>
        </resources>
        <plugins>
            <plugin>
                <groupId>io.quarkus</groupId>
                <artifactId>quarkus-maven-plugin</artifactId>
                <extensions>true</extensions>
                <executions>
                    <execution>
                        <goals>
                            <goal>build</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <systemPropertyVariables>
                        <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>
                        <maven.home>${maven.home}</maven.home>
                    </systemPropertyVariables>
                </configuration>
            </plugin>
            <plugin>
                <artifactId>maven-failsafe-plugin</artifactId>
                <executions>
                    <execution>
                        <goals>
                            <goal>integration-test</goal>
                            <goal>verify</goal>
                        </goals>
                    </execution>
                </executions>
                <configuration>
                    <systemPropertyVariables>
                        <native.image.path>${project.build.directory}/${project.build.finalName}-runner
                        </native.image.path>
                        <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>
                        <maven.home>${maven.home}</maven.home>
                    </systemPropertyVariables>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- Minimal variant: MVStore only - NO messaging (DEFAULT - WORKING) -->
        <profile>
            <id>image-minimal</id>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
            <properties>
                <image.variant>minimal</image.variant>
            </properties>
            <dependencies>
                <!-- Persistence: MVStore (file-based) -->
                <dependency>
                    <groupId>io.quarkiverse.flow</groupId>
                    <artifactId>quarkus-flow-mvstore</artifactId>
                    <version>${project.version}</version>
                </dependency>
            </dependencies>
        </profile>

        <!-- Standard variant: JPA persistence + PostgreSQL + durable-kubernetes (WORKING) -->
        <profile>
            <id>image-standard</id>
            <properties>
                <image.variant>standard</image.variant>
            </properties>
            <dependencies>
                <!-- Durable Kubernetes for HA -->
                <dependency>
                    <groupId>io.quarkiverse.flow</groupId>
                    <artifactId>quarkus-flow-durable-kubernetes</artifactId>
                    <version>${project.version}</version>
                </dependency>

                <!-- Persistence: JPA only -->
                <dependency>
                    <groupId>io.quarkiverse.flow</groupId>
                    <artifactId>quarkus-flow-jpa</artifactId>
                    <version>${project.version}</version>
                </dependency>

                <!-- JDBC: PostgreSQL -->
                <dependency>
                    <groupId>io.quarkus</groupId>
                    <artifactId>quarkus-jdbc-postgresql</artifactId>
                </dependency>
            </dependencies>
        </profile>

        <!-- Messaging variant: JPA persistence + Kafka + durable-kubernetes (WORKING) -->
        <profile>
            <id>image-messaging</id>
            <properties>
                <image.variant>messaging</image.variant>
            </properties>
            <dependencies>
                <!-- Durable Kubernetes for HA -->
                <dependency>
                    <groupId>io.quarkiverse.flow</groupId>
                    <artifactId>quarkus-flow-durable-kubernetes</artifactId>
                    <version>${project.version}</version>
                </dependency>

                <!-- Persistence: JPA only -->
                <dependency>
                    <groupId>io.quarkiverse.flow</groupId>
                    <artifactId>quarkus-flow-jpa</artifactId>
                    <version>${project.version}</version>
                </dependency>

                <!-- JDBC: PostgreSQL -->
                <dependency>
                    <groupId>io.quarkus</groupId>
                    <artifactId>quarkus-jdbc-postgresql</artifactId>
                </dependency>

                <!-- Messaging: Kafka + Flow messaging support -->
                <dependency>
                    <groupId>io.quarkus</groupId>
                    <artifactId>quarkus-messaging-kafka</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.quarkiverse.flow</groupId>
                    <artifactId>quarkus-flow-messaging</artifactId>
                    <version>${project.version}</version>
                </dependency>
            </dependencies>
        </profile>

        <!-- Native image profile -->
        <profile>
            <id>native-image</id>
            <activation>
                <property>
                    <name>native</name>
                </property>
            </activation>
            <properties>
                <quarkus.package.jar.enabled>false</quarkus.package.jar.enabled>
                <skipITs>false</skipITs>
                <quarkus.native.enabled>true</quarkus.native.enabled>
            </properties>
        </profile>
    </profiles>
</project>
