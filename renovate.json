{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>quarkiverse/renovate-config"
  ],
  "packageRules": [
    {
      "groupName": "Documentation tools",
      "matchManagers": ["npm"],
      "matchPackagePrefixes": ["@antora", "asciidoctor"]
    },
    {
      "groupName": "GitHub Actions (non-major)",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "groupName": "Quarkiverse extensions",
      "matchManagers": ["maven"],
      "matchPackagePrefixes": ["io.quarkiverse"]
    },
    {
      "groupName": "Infrastructure and Containers",
      "matchManagers": ["dockerfile", "docker-compose"],
      "matchUpdateTypes": ["minor", "patch"]
    },
    {
      "groupName": "Testing Infrastructure & Code Quality",
      "matchManagers": ["maven"],
      "matchPackagePrefixes": [
        "org.junit",
        "org.mockito",
        "org.wiremock",
        "com.github.tomakehurst",
        "org.jboss.resteasy",
        "io.rest-assured",
        "org.testcontainers",
        "org.assertj",
        "io.quarkiverse.playwright",
        "org.jacoco"
      ]
    },
    {
      "groupName": "Maven Code Formatters & Linters",
      "matchManagers": ["maven"],
      "matchPackageNames": [
        "net.revelc.code.formatter:formatter-maven-plugin",
        "net.revelc.code:impsort-maven-plugin"
      ]
    }
  ]
}
