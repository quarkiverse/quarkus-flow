{
  "request": {
    "method": "GET",
    "urlPath": "/cc/resource",
    "headers": {
      "Authorization": {
        "equalTo": "Bearer cc-access-token"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "authorized": true,
      "via": "client-credentials"
    }
  }
}
