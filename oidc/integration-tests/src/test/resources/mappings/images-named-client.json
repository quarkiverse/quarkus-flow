{
  "request": {
    "method": "GET",
    "urlPath": "/named-image-service/images",
    "headers": {
      "Accept": {
        "contains": "application/json"
      },
      "Authorization": {
        "equalTo": "Bearer named-access-token"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": [
      {
        "id": "named-1",
        "filename": "named.jpg"
      }
    ]
  }
}
