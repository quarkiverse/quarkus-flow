{
  "priority": 1,
  "request": {
    "method": "GET",
    "urlPath": "/endpoint-image-service/images",
    "headers": {
      "Accept": {
        "contains": "application/json"
      },
      "Authorization": {
        "equalTo": "Bearer token-endpoint-b"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": [
      {
        "id": "{{randomValue type='UUID'}}",
        "filename": "from-endpoint-b.jpg"
      }
    ],
    "transformers": [
      "response-template"
    ]
  }
}
