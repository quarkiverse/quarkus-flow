{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/oauth2/a/token",
    "bodyPatterns": [
      {
        "contains": "grant_type=client_credentials"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "access_token": "token-endpoint-a",
      "token_type": "Bearer",
      "expires_in": 3600
    }
  }
}
